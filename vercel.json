{
    "version": 2,
    "builds": [
        {
            "src": "nexvett-ai/api/index.ts",
            "use": "@vercel/node"
        },
        {
            "src": "nexvett-ai-client/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist/client"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/nexvett-ai/api/index.ts"
        },
        {
            "source": "/(.*)",
            "destination": "/nexvett-ai-client/$1"
        }
    ]
}